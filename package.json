{
  "name": "vue3-mobile-table",
  "version": "1.1.1",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "description": "vue3-mobile-table is a lightweight, high-performance Vue 3 mobile table solution.",
  "keywords": [
    "vue",
    "vue3",
    "mobile-table",
    "touch-table",
    "table-scroll",
    "touch-scroll",
    "移动端表格"
  ],
  "homepage": "https://lostelkbyte.github.io/vue3-mobile-table",
  "bugs": {
    "url": "https://github.com/LostElkByte/vue3-mobile-table/issues"
  },
  "license": "MIT",
  "author": {
    "name": "LostElk",
    "url": "https://github.com/LostElkByte"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LostElkByte/vue3-mobile-table.git",
    "directory": "packages/vue3-mobile-table"
  },
  "workspaces": [
    "packages/*",
    "play",
    "docs"
  ],
  "scripts": {
    "cz": "czg",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "dev": "pnpm -C play dev",
    "clean": "pnpm run clean:dist && pnpm run -r --parallel clean",
    "clean:dist": "rimraf dist",
    "build": "pnpm run -C internal/build start",
    "format": "prettier --write .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache --concurrency=auto",
    "lint:fix": "pnpm run lint --fix",
    "lint:commit": "commitlint",
    "typecheck": "pnpm run \"/^typecheck:/\"",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --composite false --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:vitest": "vue-tsc -p tsconfig.vitest.json --composite false --noEmit",
    "docs:dev": "pnpm run -C docs dev",
    "docs:build": "pnpm run -C docs build",
    "stub": "pnpm run -r --parallel stub",
    "gen:version": "tsx scripts/gen-version.ts",
    "update:version": "tsx scripts/update-version.ts",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release": "pnpm build && pnpm test && pnpm changelog",
    "prepare": "husky",
    "postinstall": "pnpm stub"
  },
  "devDependencies": {
    "@acemir/cssom": "^0.9.31",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@pnpm/find-workspace-packages": "^4.0.43",
    "@pnpm/logger": "^4.0.0",
    "@pnpm/types": "^8.10.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "catalog:",
    "@vue3-mobile-table/build": "workspace:^",
    "@vue3-mobile-table/build-utils": "workspace:^",
    "@vue3-mobile-table/eslint-config": "workspace:*",
    "consola": "^3.4.2",
    "conventional-changelog-cli": "^5.0.0",
    "cz-git": "^1.12.0",
    "czg": "^1.12.0",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "rimraf": "^4.4.1",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.21.0",
    "typescript": "~5.5.4",
    "unbuild": "^2.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": ">= 20"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "cross-spawn": ">=7.0.5",
      "serialize-javascript": ">=7.0.5",
      "esbuild": ">=0.25.0",
      "unhead": ">=2.1.11",
      "@pnpm/cafs": ">=7.0.5",
      "lodash-es": ">=4.18.0",
      "lodash": ">=4.18.0"
    }
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx,md,json}": [
      "eslint --fix --concurrency=auto",
      "prettier --write"
    ]
  }
}
