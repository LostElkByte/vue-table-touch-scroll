{
  extends: ['config:base', 'schedule:weekly', 'group:allNonMajor'],
  labels: ['dependencies'],
  rangeStrategy: 'bump',
  packageRules: [
    {
      depTypeList: ['peerDependencies'],
      enabled: false,
    },
  ],
  ignoreDeps: [
    'node',
    // jsdom version is pinned for compatibility
    'jsdom',
    // vitest updates need careful testing
    'vitest',
  ],
}
