{
  "name": "vue3-mobile-table",
  "version": "1.1.2",
  "description": "vue3-mobile-table is a lightweight, high-performance Vue 3 mobile table solution.",
  "keywords": [
    "vue",
    "vue3",
    "mobile-table",
    "touch-table",
    "table-scroll",
    "touch-scroll",
    "移动端表格"
  ],
  "homepage": "https://lostelkbyte.github.io/vue3-mobile-table",
  "bugs": {
    "url": "https://github.com/LostElkByte/vue3-mobile-table/issues"
  },
  "license": "MIT",
  "author": {
    "name": "LostElk",
    "url": "https://github.com/LostElkByte"
  },
  "main": "lib/index.js",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.js"
    },
    "./es": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./lib": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js"
    },
    "./*": "./*"
  },
  "unpkg": "dist/index.full.js",
  "jsdelivr": "dist/index.full.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LostElkByte/vue3-mobile-table.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "lib",
    "es",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "*",
    "vue": "catalog:"
  }
}
